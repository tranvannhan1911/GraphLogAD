# ===== PATH =====
ROOT=dataset/BGL
DATA=dataset/BGL/BGL.log_structured.csv
OUT_DIR=output
CKPT_DIR=checkpoints

# ===== MODEL =====
MODEL_PATH=bert-base-uncased

# ===== GRAPH GENERATION =====
INFERENCE=regex   # regex or prompt
STRATEGY=0    # P1 (0) or P2 (1)
INTERVAL=1s

# ===== NER =====
DATA_NAME=BGL
NUM_SHOTS=5
N_GRAMS=3
NEG_RATE=1
LABEL_METHOD=prompt # regex or prompt
EPOCHS=3
TRAIN_BATCH=8
EVAL_BATCH=8
GRAD_CUM_STEPS=1
SEED=42
NER_PRETRAINED_MODEL=facebook/bart-base

# ===== TRAINING =====
CKPT=checkpoints
TRAIN_BATCH_SIZE=64
EVAL_BATCH_SIZE=64
LAMBDA=0.1
CLASSIFICATION=node
MAX_LENGTH=1024
LR=1e-3
LAYERS=3
WEIGHT_DECAY=1e-5
GLOBAL_WEIGHT=0.5
MODEL_TYPE=ae-dynamic

# ===== PYTORCH =====
export PYTORCH_ENABLE_MPS_FALLBACK=1